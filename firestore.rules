rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Properties: Publicly readable, only admins (if defined) or system can write
    // For now, let's allow read to everyone
    match /properties/{propertyId} {
      allow read: if true;
      allow write: if false; // Only via console or system for now
    }

    match /developments/{devId} {
      allow read: if true;
      allow write: if false;
    }

    match /agents/{agentId} {
      allow read: if true;
      allow write: if false;
    }

    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
